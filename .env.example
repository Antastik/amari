# ─────────────────────────────────────────────────────────────────────────────
# Amari environment
#
# API keys are OPTIONAL here. By default you enter them in the in-app Settings
# panel (stored in your browser's localStorage and sent with each request).
# Setting them here makes them server-side defaults — useful for a personal
# Vercel deployment or a shared local instance.
# ─────────────────────────────────────────────────────────────────────────────

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Google (Gemini, via the OpenAI-compatible endpoint)
GEMINI_API_KEY=

# Moonshot / Kimi
MOONSHOT_API_KEY=

# OpenRouter (gateway to many models)
OPENROUTER_API_KEY=

# Local Ollama server (only used when running locally)
OLLAMA_BASE_URL=http://localhost:11434/v1

# Google (Drive + Gmail) OAuth client — optional.
# You can also enter these in-app under Settings → Google (stored in ~/.amari).
# Create an OAuth "Web application" client in Google Cloud, enable the Drive &
# Gmail APIs, and add the redirect URI http://localhost:3000/api/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Override where Amari stores Google credentials/tokens (default ~/.amari)
# AMARI_CONFIG_DIR=

# Workspace directory the agent's file/shell tools operate inside.
# Defaults to ./workspace under the project root.
AMARI_WORKSPACE=

# Force-disable local tools (filesystem + shell) even when running locally.
# These are always disabled on Vercel / serverless automatically.
# AMARI_DISABLE_LOCAL_TOOLS=1
